.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 8rpx;
}

.family-select {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.select-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.picker-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.member-detail {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.member-detail text {
  font-size: 24rpx;
  color: #999999;
}

.member-detail .divider {
  margin: 0 12rpx;
  color: #cccccc;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-btn.edit {
  background: #e8f5e9;
  color: #4caf50;
}

.action-btn.delete {
  background: #ffebee;
  color: #f44336;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.gender-option.active {
  background: #e8f5e9;
  color: #667eea;
  border-color: #667eea;
}