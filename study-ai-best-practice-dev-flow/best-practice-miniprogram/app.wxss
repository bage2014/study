page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666666;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
}

.btn-danger {
  background: #ff6b6b;
  color: #ffffff;
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  text-align: center;
  border: none;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-group .btn-primary,
.btn-group .btn-secondary {
  flex: 1;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-item input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-item input:focus {
  border-color: #667eea;
}

.form-item textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #999999;
  font-size: 26rpx;
}

.text-primary {
  color: #667eea;
}

.text-danger {
  color: #ff6b6b;
}

.header {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.sub-header {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.list-item .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.list-item .info {
  flex: 1;
}

.list-item .info .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.list-item .info .desc {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.list-item .arrow {
  width: 40rpx;
  height: 40rpx;
  border-right: 4rpx solid #cccccc;
  border-bottom: 4rpx solid #cccccc;
  transform: rotate(-45deg);
}

.divider {
  height: 16rpx;
  background: #f5f5f5;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state .icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-body {
  padding: 0 32rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.modal-footer button {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  background: transparent;
}

.modal-footer .btn-cancel {
  color: #999999;
  border-right: 2rpx solid #f0f0f0;
}

.modal-footer .btn-confirm {
  color: #667eea;
}

.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.gap-20 {
  gap: 20rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-20 {
  padding: 20rpx;
}