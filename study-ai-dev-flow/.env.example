# AI Pipeline Platform - Environment Configuration
# Copy this file to .env and fill in your API keys

# DeepSeek AI Configuration (Primary)
AI_DEEPSEEK_API_KEY=your_deepseek_api_key_here
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI Configuration (Optional)
AI_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (Optional)
AI_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (Optional - for local models)
AI_OLLAMA_BASE_URL=http://localhost:11434

# Model Providers
AI_REQUIREMENT_MODEL_PROVIDER=deepseek
AI_CODEGEN_MODEL_PROVIDER=deepseek

# Model Names
AI_REQUIREMENT_MODEL=deepseek-chat
AI_CODEGEN_MODEL=deepseek-chat

# Temporal Service
TEMPORAL_SERVICE_ADDRESS=localhost:7233
